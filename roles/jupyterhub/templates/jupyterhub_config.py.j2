# Managed by Ansible (ansible-jupyterhub) — do not edit manually
import sys

c = get_config()  # noqa: F821

# === Network ===
c.JupyterHub.bind_url = '{{ jupyterhub_bind_url }}'
c.JupyterHub.base_url = '{{ jupyterhub_base_url }}'

# === Spawner ===
c.JupyterHub.spawner_class = '{{ jupyterhub_spawner }}'
c.Spawner.default_url = '{{ jupyterhub_spawner_default_interface }}'

# === State ===
c.JupyterHub.db_url = 'sqlite:///{{ jupyterhub_state_dir }}/jupyterhub.sqlite'
c.JupyterHub.cookie_secret_file = '{{ jupyterhub_state_dir }}/jupyterhub_cookie_secret'

# === Idle culler ===
c.JupyterHub.services = [
    {
        'name': 'idle-culler',
        'command': [
            sys.executable,
            '-m', 'jupyterhub_idle_culler',
            '--timeout={{ jupyterhub_idle_timeout }}',
            '--cull-every={{ jupyterhub_idle_cull_every }}',
            '--max-age={{ jupyterhub_idle_max_age }}',
        ],
    }
]
c.JupyterHub.load_roles = [
    {
        'name': 'idle-culler',
        'scopes': ['list:users', 'read:users:activity', 'read:servers', 'delete:servers'],
        'services': ['idle-culler'],
    }
]

# === Authentication (PAM — Linux system users) ===
c.Authenticator.admin_users = set()
c.LocalAuthenticator.create_system_users = False
